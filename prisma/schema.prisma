generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- NextAuth Adapter Models ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- E.O.S. Core Models ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("EMPLOYEE")
  passcode      String?

  accounts Account[]
  sessions Session[]

  tasksAssigned        Task[]                @relation("Assignee")
  tasksCreated         Task[]                @relation("Creator")
  messages             Message[]
  pushSubs             PushSubscription[]
  vto                  VTO?
  scorecardMeasurables ScorecardMeasurable[] @relation("UserMeasurables")
  meetingIssues        MeetingIssue[]
  seats                Seat[]
  ownedProcesses       Process[]             @relation("ProcessOwner")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("TODO")
  status      String    @default("OPEN")
  persona     String    @default("TRUERANK_DIGITAL")
  dueDate     DateTime?
  gCalEventId String?

  creatorId String
  creator   User   @relation("Creator", fields: [creatorId], references: [id])

  assigneeId String
  assignee   User   @relation("Assignee", fields: [assigneeId], references: [id])

  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint String @unique
  p256dh   String
  auth     String
}

// --- EOS Models ---
model VTO {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  coreValues        String?
  coreFocus         String?
  tenYearTarget     String?
  marketingStrategy String?
  threeYearPicture  String?
  oneYearPlan       String?
  quarterlyRocks    String?
  issuesList        String?

  // Specific feedback/prompts from Admins for this user (JSON string or specific fields)
  feedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VTOSettings {
  id                      String  @id @default(cuid())
  // Global guidance prompts set by Jon/Admins
  coreValuesPrompt        String?
  coreFocusPrompt         String?
  tenYearTargetPrompt     String?
  marketingStrategyPrompt String?
  threeYearPicturePrompt  String?
  oneYearPlanPrompt       String?
  quarterlyRocksPrompt    String?
  issuesListPrompt        String?

  updatedAt DateTime @updatedAt
}

// --- Scorecard Models ---
model ScorecardMeasurable {
  id       String @id @default(cuid())
  title    String
  goal     Float // The target number
  operator String @default(">=") // >=, <=, ==
  userId   String
  user     User   @relation("UserMeasurables", fields: [userId], references: [id], onDelete: Cascade)

  values ScorecardValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScorecardValue {
  id           String              @id @default(cuid())
  measurableId String
  measurable   ScorecardMeasurable @relation(fields: [measurableId], references: [id], onDelete: Cascade)

  value      Float
  weekEnding DateTime // Represents the end of the week (usually Sunday)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([measurableId, weekEnding])
}

// --- Meeting Models ---
model Meeting {
  id        String    @id @default(cuid())
  title     String    @default("Level 10 Meeting")
  startTime DateTime  @default(now())
  endTime   DateTime?
  status    String    @default("PLANNED") // PLANNED, ACTIVE, COMPLETED

  issues MeetingIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingIssue {
  id          String  @id @default(cuid())
  title       String
  description String?
  priority    Int     @default(0)
  status      String  @default("OPEN") // OPEN, SOLVED

  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Accountability Chart Models ---
model Seat {
  id          String  @id @default(cuid())
  title       String
  description String? // 5 roles/responsibilities

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  reportsToId  String?
  reportsTo    Seat?   @relation("Reporting", fields: [reportsToId], references: [id], onDelete: SetNull)
  subordinates Seat[]  @relation("Reporting")

  // GWC (Get it, Want it, Capacity)
  getIt    Boolean @default(false)
  wantIt   Boolean @default(false)
  capacity Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Process Library Models ---
model Process {
  id          String  @id @default(cuid())
  title       String
  description String?
  content     String? // Step-by-step documentation
  ownerId     String
  owner       User    @relation("ProcessOwner", fields: [ownerId], references: [id])

  isCore         Boolean @default(false)
  adherenceScore Int     @default(100) // 0-100% adherence

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
